

# Task 1

np.random.seed(42)

scores = np.random.randint(50, 101, (5, 4))

print("Scores:")
print(scores)

# 3rd student 2nd subject
print("3rd student 2nd subject:", scores[2][1])

# last 2 students
print("Last 2 students:")
print(scores[3:5])

# first 3 students subjects 2 and 3
print("First 3 students, subject 2 and 3:")
print(scores[0:3, 1:3])


# Task 2

# column wise mean
mean_scores = np.round(np.mean(scores, axis=0), 2)
print("Mean per subject:", mean_scores)

# adding curve
curve = [5, 3, 7, 2]
curved_scores = scores + curve

# make sure not more than 100
curved_scores[curved_scores > 100] = 100

print("Curved Scores:")
print(curved_scores)

# best score per student
best_scores = np.max(curved_scores, axis=1)
print("Best score per student:", best_scores)


# Task 3

# row min and max
row_min = np.min(curved_scores, axis=1).reshape(5,1)
row_max = np.max(curved_scores, axis=1).reshape(5,1)

# normalization
normalized = (curved_scores - row_min) / (row_max - row_min)

print("Normalized scores:")
print(normalized)

# highest value position
max_pos = np.unravel_index(np.argmax(normalized), normalized.shape)
print("Highest normalized value position:", max_pos)

# scores above 90
above_90 = curved_scores[curved_scores > 90]
print("Scores above 90:", above_90)
